<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.csu.dao.mapper.SupplierMapper">

    <select id="selectAllSuppliers" resultType="com.csu.model.Entity.Supplier">
        SELECT * FROM supplier ORDER BY suppid
    </select>

    <select id="searchByName" resultType="com.csu.model.Entity.Supplier">
        SELECT * FROM supplier
        WHERE LOWER(name) LIKE LOWER(CONCAT('%', #{name}, '%'))
        ORDER BY suppid
    </select>

    <select id="selectActiveSuppliers" resultType="com.csu.model.Entity.Supplier">
        SELECT * FROM supplier WHERE status = 'A' ORDER BY suppid
    </select>

</mapper>
